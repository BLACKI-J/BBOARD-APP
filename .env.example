GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Sécurité - PIN utilisé uniquement lors du premier démarrage
# Remplacez impérativement cette valeur avant le déploiement initial.
INITIAL_ADMIN_PIN=change_me_4_digits

# Activez en production lorsque l'application est servie exclusivement en HTTPS.
COOKIE_SECURE=false

# Sécurité (CORS) - Liste des domaines autorisés séparés par des virgules
# Exemple: ALLOWED_ORIGINS=https://mon-domaine.com,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
